PORT=3000
PUBLIC_BASE_URL=

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_DISPLAY_PHONE_NUMBER=
# Meta Developers -> App Settings -> App Secret. Used to validate webhook signatures.
WHATSAPP_APP_SECRET=
REQUIRE_WEBHOOK_SIGNATURE=true
ALLOW_UNSIGNED_WEBHOOKS=false
UNSIGNED_WEBHOOK_EXPIRES_AT=
WEBHOOK_PATH_SECRET=
DOCTOR_WHATSAPP_NUMBER=5210000000000

# Password/token for /inbox and /debug/config. Do not reuse WHATSAPP_VERIFY_TOKEN.
INBOX_PASSWORD=
INBOX_PASSWORD_HASH=
COOKIE_SECRET=
INBOX_SESSION_HOURS=8
MAX_REQUEST_BYTES=256000
WEBHOOK_RATE_LIMIT_PER_MINUTE=600
WEBHOOK_PHONE_RATE_LIMIT_PER_MINUTE=30
INBOX_RATE_LIMIT_PER_MINUTE=60
INBOX_SEND_RATE_LIMIT_PER_MINUTE=20
INBOX_LOGIN_RATE_LIMIT_PER_15_MINUTES=5
ENABLE_REMINDER_WORKER=true
REMINDER_WORKER_INTERVAL_MS=60000

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI provider: local is free and handles basic appointment messages. Use gemini/openai for richer understanding.
AI_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Clinic rules
CLINIC_TIMEZONE=America/Mexico_City
CLINIC_NAME=Consultorio Ginecologico
APPOINTMENT_MINUTES=40
WORK_DAYS=1,2,3,4,5
WORK_START=16:40
WORK_END=20:00
