# ============================================================
# MODO PILOTO RECOMENDADO — copiar estas variables a Render
# Esencial: WhatsApp + Google Calendar + Supabase + Inbox
# ============================================================
# NODE_ENV=production
# AI_PROVIDER=local
# REQUIRE_WEBHOOK_SIGNATURE=true
# ALLOW_UNSIGNED_WEBHOOKS=false
# REQUIRE_DB_FOR_APPOINTMENTS=true
# SHEETS_ENABLED=false
# ENABLE_REMINDER_WORKER=false
# ENABLE_PATIENT_REMINDER_TEMPLATES=false
# RESEND_API_KEY=                  # requerido solo si enviaras confirmaciones/cancelaciones/resultados por correo
# ENABLE_DAILY_REPORT=false
# COLD_LEAD_FOLLOWUP_ENABLED=false
# ENABLE_POST_APPOINTMENT_SURVEY=false
# INBOX_ALLOW_LEGACY_TOKEN_ACCESS=false
# FORWARD_CONVERSATION_COPIES=false
# FORWARD_CONVERSATION_BODIES=false
# ============================================================

NODE_ENV=production
PORT=10000
PUBLIC_BASE_URL=

# Meta WhatsApp Cloud API
# Usa WHATSAPP_TOKEN como variable principal. WHATSAPP_ACCESS_TOKEN queda como fallback legacy.
# Si ambas existen y son distintas, el bot usara WHATSAPP_TOKEN y avisara en /health/ready.
WHATSAPP_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
REQUIRE_WEBHOOK_SIGNATURE=true
ALLOW_UNSIGNED_WEBHOOKS=false
UNSIGNED_WEBHOOK_EXPIRES_AT=
WEBHOOK_PATH_SECRET=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_DISPLAY_PHONE_NUMBER=
DOCTOR_WHATSAPP_NUMBER=5210000000000
WHATSAPP_SEND_DRY_RUN=false

# Rate limits and request limits
WEBHOOK_RATE_LIMIT_PER_MINUTE=120
WEBHOOK_PHONE_RATE_LIMIT_PER_MINUTE=10
INBOX_RATE_LIMIT_PER_MINUTE=60
INBOX_LOGIN_RATE_LIMIT_PER_15_MINUTES=5
INBOX_SEND_RATE_LIMIT_PER_MINUTE=20
INBOX_ACTION_RATE_LIMIT_PER_MINUTE=30
MAX_REQUEST_BYTES=128000
INBOX_MEDIA_MAX_BYTES=16000000
RESULTS_EMAIL_MAX_BYTES=10000000

# Supabase/Postgres. Keep service role only on backend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_LABEL=agenda de citas DRA. CARRANZA
GOOGLE_CALENDAR_ID=ginecologiaintegralgto@gmail.com
GOOGLE_CALENDAR_EVENT_COLOR_ID=9
GOOGLE_CALENDAR_EVENT_SUMMARY_PREFIX=DRA. CARRANZA-
# Calendarios que bloquean disponibilidad. Para este piloto usa solo la agenda oficial.
GOOGLE_BUSY_CALENDAR_IDS=ginecologiaintegralgto@gmail.com
GOOGLE_REDIRECT_URI=

# Inbox auth
INBOX_PASSWORD=
INBOX_PASSWORD_HASH=
COOKIE_SECRET=
INBOX_SESSION_HOURS=8

# Bot operation
ENABLE_REMINDER_WORKER=false
ENABLE_PATIENT_REMINDER_TEMPLATES=false
WHATSAPP_REMINDER_TEMPLATE_24H=
WHATSAPP_REMINDER_TEMPLATE_2H=
# Plantilla aprobada (Utility) para cancelaciones fuera de ventana 24h. Dejar vacio si no aplica.
WHATSAPP_CANCELLATION_TEMPLATE=
# Plantilla aprobada (Utility) para reagendar fuera de ventana 24h. Dejar vacio si no aplica.
WHATSAPP_RESCHEDULE_TEMPLATE=
# Plantillas aprobadas para responder fuera de ventana 24h desde el inbox.
WHATSAPP_REENGAGEMENT_TEMPLATE=
WHATSAPP_RESULTS_EMAIL_TEMPLATE=
WHATSAPP_TEMPLATE_LANGUAGE=es_MX
REQUIRE_DB_FOR_APPOINTMENTS=true
REQUIRE_SUPABASE_FOR_APPOINTMENTS=true
APPOINTMENT_LOCK_MINUTES=10
REMINDER_WORKER_INTERVAL_MS=60000
BOT_PAUSE_TIMEOUT_MINUTES=120
FORWARD_CONVERSATION_COPIES=false
FORWARD_CONVERSATION_BODIES=false

# Clinic rules
CLINIC_TIMEZONE=America/Mexico_City
CLINIC_NAME=Consultorio Ginecologico
APPOINTMENT_DURATION_MINUTES=40
APPOINTMENT_MINUTES=40
APPOINTMENT_BUFFER_MINUTES=0
MIN_APPOINTMENT_ADVANCE_HOURS=0
CLINIC_WORK_DAYS=1,2,3,4,5
WORK_DAYS=1,2,3,4,5
CLINIC_START_TIME=16:40
WORK_START=16:40
CLINIC_END_TIME=20:00
WORK_END=20:00
MAX_OFFERED_SLOTS=6
CONSULTATION_PRICE=1000
PROMOTION_PRICE=1200
# Opcional: lista lo que incluye la promo. Dejar vacio para respuesta generica segura.
PROMOTION_DETAILS=
CLINIC_ADDRESS=
INCLUDE_SENSITIVE_APPOINTMENT_NOTES=false
MASK_PATIENT_PHONE_IN_CALENDAR=true
INCLUDE_PATIENT_CONTACT_IN_CALENDAR=false

# AI — usar local para piloto (gratis, sin dependencias externas)
AI_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Hardening operativo
EXTERNAL_REQUEST_TIMEOUT_MS=8000
EXTERNAL_REQUEST_RETRIES=2
INBOX_ALLOW_LEGACY_TOKEN_ACCESS=false

# ── Funciones opcionales — apagadas en piloto ──────────────
EMAIL_OPTIONAL=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ENABLE_DAILY_REPORT=false
DAILY_REPORT_HOUR=22
COLD_LEAD_FOLLOWUP_ENABLED=false
COLD_LEAD_FOLLOWUP_HOURS=6
ENABLE_POST_APPOINTMENT_SURVEY=false
POST_APPOINTMENT_SURVEY_DELAY_HOURS=2

# Dias bloqueados (vacaciones). Ejemplo: BLOCKED_DATES=2026-12-25,2026-12-31
BLOCKED_DATES=
# Rangos bloqueados. Ejemplo: BLOCKED_DATE_RANGES=2026-07-14:2026-07-21
BLOCKED_DATE_RANGES=

# Google Sheets — apagado en piloto
SHEETS_ENABLED=false
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
